# Server Configuration
PORT=5001                          # Port for the Express server (Railway auto-assigns this)

# Database
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/code-battle-arena  # MongoDB Atlas connection string

# Cache / Queue
REDIS_URL=rediss://default:token@host:6379  # Upstash Redis URL (use rediss:// for TLS)

# Authentication
JWT_SECRET=your-256-bit-secret-here         # Secret for signing JWTs — use a strong random string
JWT_EXPIRES_IN=7d                           # Token expiration duration

# Code Execution (Judge0)
JUDGE0_API_URL=https://judge0-ce.p.swisspol.ch  # Judge0 CE API — free public instance or self-hosted
JUDGE0_API_KEY=                                  # RapidAPI key (only needed if using judge0-ce.p.rapidapi.com)

# Frontend
CLIENT_URL=http://localhost:5173            # Frontend URL for CORS — update for production (e.g., https://your-app.vercel.app)

# Environment
NODE_ENV=development                        # Set to "production" in deployment
